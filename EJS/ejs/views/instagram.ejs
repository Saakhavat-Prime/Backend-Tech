<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>instagram</title>
    <style>
        img{
            width: 100px;
            height: 100px;
            /* document.body{
                background-color: pink;
            } */
        }
    </style>
   
</head>

<body>
    <h1>this page belongs to @ <%= data.name %>
    </h1>
    <button>Follow</button>
    <button>Message</button>

    <p>
        followers <%= data.followers %> &nbsp;&nbsp;&nbsp;&nbsp; followings <%= data.followings %>
    </p>
    <hr>
    

    <% for (let post of data.posts) { %>
        <img src="<%= post.image %>" alt="curruntly not avalible">
    <p>
        Likes <%= post.likes %> &nbsp;&nbsp;&nbsp;&nbsp; Comments <%= post.comments %>
    </p>

        
    <% } %>

    <%- include("includes/footer.ejs") %>

</body>

</html>